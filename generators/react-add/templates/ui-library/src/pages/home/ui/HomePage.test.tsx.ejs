import { render, screen } from '@testing-library/react';
import { describe, expect, it } from 'vitest';
import { AppProviders } from '@/app/providers';
import { HomePage } from './HomePage';

describe('HomePage', () => {
  it('renders the generated UI library content', () => {
    render(
      <AppProviders>
        <HomePage />
      </AppProviders>,
    );

    expect(
      screen.getByRole('heading', { name: '<%= appDisplayName %>' }),
    ).toBeInTheDocument();
    expect(
      screen.getByText(/ui-library feature wires Material UI theme setup/i),
    ).toBeInTheDocument();
    expect(
      screen.getByRole('heading', { name: /Shared UI, ready to extend/i }),
    ).toBeInTheDocument();
    expect(
      screen.getByRole('button', { name: /Launch feature work/i }),
    ).toBeInTheDocument();
  });
});
