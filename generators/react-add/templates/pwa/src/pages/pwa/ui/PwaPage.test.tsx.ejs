import { render, screen } from '@testing-library/react';
import { MemoryRouter } from 'react-router-dom';
import { describe, expect, it, vi } from 'vitest';
import { PwaPage } from './PwaPage';

vi.mock('@/features/pwa', () => ({
  usePwaState: () => ({
    canInstall: true,
    installApp: vi.fn(async () => undefined),
    isInstalled: false,
    isOfflineReady: false,
    isOnline: true,
    isUpdateAvailable: false,
    updateApp: vi.fn(async () => undefined),
  }),
}));

describe('PwaPage', () => {
  it('renders the generated PWA guide content', () => {
    render(
      <MemoryRouter>
        <PwaPage />
      </MemoryRouter>,
    );

    expect(
      screen.getByRole('heading', {
        name: /Offline-ready app shell and install prompts are wired in/i,
      }),
    ).toBeInTheDocument();
    expect(
      screen.getByRole('button', { name: /Install app/i }),
    ).toBeInTheDocument();
    expect(
      screen.getByRole('link', { name: /Return to the home page/i }),
    ).toHaveAttribute('href', '/');
  });
});
