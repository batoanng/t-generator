import type { PropsWithChildren } from 'react';
import { Auth0Provider } from '@auth0/auth0-react';
import { env } from '@/shared/config';

type AuthRedirectState = {
  returnTo?: string;
};

function getAuthorizationParams() {
  return {
    redirect_uri: window.location.origin,
    ...(env.auth0.audience ? { audience: env.auth0.audience } : {}),
  };
}

export function Auth0ProviderWithNavigate({
  children,
}: PropsWithChildren) {
  if (!env.auth0.isConfigured) {
    return <>{children}</>;
  }

  return (
    <Auth0Provider
      domain={env.auth0.domain}
      clientId={env.auth0.clientId}
      authorizationParams={getAuthorizationParams()}
      onRedirectCallback={(appState?: AuthRedirectState) => {
        const returnTo = appState?.returnTo || '/auth';
        const redirectUrl = new URL(returnTo, window.location.origin);

        window.location.replace(redirectUrl.toString());
      }}
    >
      {children}
    </Auth0Provider>
  );
}
